generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

model User {
    id                  String   @id @default(cuid())
    email               String   @unique
    passwordHash        String
    isTemporaryPassword Boolean  @default(false)
    status              String   @default("PENDING_VERIFICATION") // ACTIVE | BLOCKED | PENDING_VERIFICATION
    role                String   @default("NON_TECHNICAL")        // NON_TECHNICAL | DEV | ADMIN | SUPER_ADMIN
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt
}

model AuditLog {
    id        String   @id @default(cuid())
    action    String // tRPC mutation path, e.g. "admin.users.updateStatus"
    userId    String? // actor id, null when unauthenticated
    userEmail String? // actor email snapshot at the time of the action
    input     String? // sanitized JSON of the mutation input
    createdAt DateTime @default(now())

    @@index([createdAt])
}
