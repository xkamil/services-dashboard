generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  isTemporaryPassword Boolean  @default(false)
  role                String   @default("USER") // USER | ADMIN | SUPER_ADMIN
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  secrets UserSecret[]
}

model UserSecret {
  id         String   @id @default(cuid())
  userId     String
  key        String // registry key, e.g. "GITHUB_API_TOKEN" (see src/lib/secrets.ts)
  ciphertext String // AES-256-GCM payload: base64(iv).base64(authTag).base64(data)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String // tRPC mutation path, e.g. "admin.users.updateRole"
  userId    String? // actor id, null when unauthenticated
  userEmail String? // actor email snapshot at the time of the action
  input     String? // sanitized JSON of the mutation input
  createdAt DateTime @default(now())

  @@index([createdAt])
}
